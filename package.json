{
  "name": "kre8r",
  "version": "1.0.0",
  "description": "Kre8Ωr — AI-native content production OS for 7 Kin Homestead",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "electron": "electron .",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist": "electron-builder --win --mac",
    "generate-icons": "node scripts/generate-icons.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "chokidar": "^5.0.0",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "fluent-ffmpeg": "^2.1.3",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "playwright": "^1.59.1",
    "sharp": "^0.34.5",
    "sql.js": "^1.14.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "app.kre8r.desktop",
    "productName": "Kre8Ωr",
    "copyright": "Copyright © 2026 Kre8Ωr",
    "icon": "public/images/kre8r-icon",
    "files": [
      "electron/**/*",
      "public/**/*",
      "src/**/*",
      "database/schema.sql",
      "server.js",
      "package.json",
      "creator-profile.json",
      "!node_modules",
      "!*.db",
      "!backups/**"
    ],
    "extraResources": [],
    "win": {
      "target": "nsis",
      "icon": "public/images/kre8r-icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/images/kre8r-icon.png",
      "category": "public.app-category.productivity"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "dmg": {
      "background": "#0e0f0e",
      "icon": "public/images/kre8r-icon.png"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
